# URL backend API (auto_ai_auth)
# Локально: http://localhost:8001/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001/api/v1

# URL сканера — куда пробрасывать OAuth callback после авторизации
# Auth UI на 3001, сканер на 3000
NEXT_PUBLIC_SCANNER_APP_ORIGIN=http://localhost:3000

# URL callback сканера для "Подключить приложение" (по умолчанию http://localhost:3001/auth/callback)
# Задаётся в Django: SCANNER_WEB_CALLBACK_URL
